	public void declareVariable() {
		
		/* 변수 선언 방법: 자료형(DataType) 변수식별자(변수명); 
		 * ex) int price;
		 */
		
		/* 초기화(Initialization): 변수는 공간이니까, 변수라는 공간에 이 값을 대입하겠다는 선언.
		 * 자료형(DataType) 변수식별자(변수명) = 값; 
		 * =: assignment 대입연산자
		 * 초기화를 통해 대입한 값을 초기값이라고 함.
		 * 변수는 자신이 선언된 {scope}에서만 사용할 수 있음. = local variable(지역변수)
		 * 변수에 값을 대입하고 출력하기 위해서는 선언 및 초기화 작업이 필요함.
		 */
		
		/* 변수 명명 규칙
		 * 1) 명사적 의미를 갖게 해줌.
		 * 2) 첫 글자는 '소문자'로 표기. 띄어쓰기 이후 첫 글자는 대문자로 표기. (공백없음.)
		 */
		
		/* 2. 변수의 자료형
		 * Java의 기본자료형, 원시자료형(Primitive Type)
		 * 1) 논리자료형(논리 값: true / false) ex) boolean isTrue;
		 */
		
		boolean isTrue;
		isTrue = true; //초기화
		System.out.println(isTrue);
		isTrue = false; //대입
		System.out.println(isTrue);
		
		/* 2) 숫자자료형 -> 선언과 동시에 초기화
		 * 2-1) 정수형: 4가지 존재 - byte, short, int, long(숫자 뒤에 L). -> 담을 수 있는 값의 크기가 다름.
		 * 2-2) 실수형: 2가지 존재 - float(숫자 뒤에 F), double(기본 인식).  
		 */

		byte byteNumber = 9; // 1Byte = 8Bit -> 0~255
		short shortNumber = 90; // 2Byte
		int intNumber = 900; // 4Byte
		long longNumber = 9000; // 8Byte
		float floatNumber = 0.9F; // 4Byte
		double doubleNumber = 0.09; // 8Byte
		
		System.out.println(byteNumber);
		System.out.println(shortNumber);
		System.out.println(intNumber);
		System.out.println(longNumber);
		System.out.println(floatNumber);
		System.out.println(doubleNumber);
		
		/* 3) (단일)문자형
		 * 반드시 홑따옴표'' 붙여야 함.
		 * char money = '돈';
		 */
		char money = '돈';
		System.out.println(money);
		
		/* 4) 문자열
		 * 반드시 홑따옴표'' 붙여야 함.
		 * char money = '돈';
		 */
		
		
		/*
		 * 식별자(Identifier): 클래스, 메소드, 변수 등 개발자가 만들어서 식별할 수 있게 하는 것.
		 * 식별자 생성 규칙
		 * 1) keyword(예약어=보라글자)는 식별자로 사용할 수 없음.
		 * 2) 공백은 포함 불가
		 * 3) 특수문자는 _$ 두 가지만 사용 가능.
		 * 4) 숫자로 시작 불가.
		 */
		
		/* 개발자 약속
		 * 1) 식별자 생성할 때 영어만 사용한다.
		 * 2) 클래스, 인터페이스 명명할 때 첫 글자는 대문자로 표기. 띄어쓰기 이후 첫 글자도 대문자로 표기. (공백없음.)
		 */
		
		/* 메소드 명명 규칙
		 * 1) 동사적 의미를 갖게 해줌.
		 * 2) 첫 글자는 '소문자'로 표기. 띄어쓰기 이후 첫 글자는 대문자로 표기. (공백없음.)
		 * 3) 식별자 뒤에 반드시 한 쌍의 소괄호()를 붙인다.
		 * 4) 메소드에는 일반적으로 _를 사용하지 않음.
		 * ex) join(), signUp()
		 */
		
		/* 상수 명명 규칙
		 * 1) 모든 글자를 '대문자'로 표기. 띄어쓰기는 _로 대체. (공백없음.)
		 * ex) LOGIN_OK
		 */
		
	}
	

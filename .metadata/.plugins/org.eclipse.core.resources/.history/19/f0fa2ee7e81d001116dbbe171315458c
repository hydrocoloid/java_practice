package com.kh.first;

import javax.swing.*;
import java.awt.*;

public class PikachuDrawer 

extends JPanel {

    @Override
    protected void paintComponent(Graphics g) {
        super.paintComponent(g);
        Graphics2D g2 = (Graphics2D) g;
        // 선을 부드럽게 만드는 설정
        g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);

        // 1. 귀 그리기 (검은 끝부분)
        g2.setColor(Color.BLACK);
        g2.fillOval(50, 30, 40, 100);  // 왼쪽 귀 끝
        g2.fillOval(210, 30, 40, 100); // 오른쪽 귀 끝

        // 2. 얼굴 (노란색 원)
        g2.setColor(Color.YELLOW);
        g2.fillOval(50, 80, 200, 180); // 얼굴 몸체
        g2.fillOval(55, 50, 30, 80);   // 왼쪽 귀 노란부분
        g2.fillOval(215, 50, 30, 80);  // 오른쪽 귀 노란부분

        // 3. 눈 (검은색)
        g2.setColor(Color.BLACK);
        g2.fillOval(90, 130, 25, 25);  // 왼쪽 눈
        g2.fillOval(185, 130, 25, 25); // 오른쪽 눈

        // 4. 볼 (빨간색)
        g2.setColor(Color.RED);
        g2.fillOval(70, 180, 40, 40);  // 왼쪽 볼
        g2.fillOval(190, 180, 40, 40); // 오른쪽 볼

        // 5. 입 (선 그리기)
        g2.setColor(Color.BLACK);
        g2.drawArc(125, 170, 25, 20, 180, 180); // 입 왼쪽
        g2.drawArc(150, 170, 25, 20, 180, 180); // 입 오른쪽
    }

    public static void main(String[] args) {
        JFrame frame = new JFrame("Java Pikachu");
        PikachuDrawer panel = new PikachuDrawer();
        
        frame.add(panel);
        frame.setSize(320, 350);
        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        frame.setLocationRelativeTo(null); // 화면 중앙에 배치
        frame.setVisible(true);
    }
}
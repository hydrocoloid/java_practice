package com.kh.variable;

public class Printf {

	public static void main(String[] args) {
		
		boolean isTrue;
		isTrue = true; //초기화
		
		byte byteNumber = 9; // 1Byte = 8Bit -> 0~255
		short shortNumber = 90; // 2Byte
		int intNumber = 900; // 4Byte
		long longNumber = 9000; // 8Byte
		float floatNumber = 0.9F; // 4Byte
		double doubleNumber = 0.09; // 8Byte
		char money = 'm';
		String str = "money";
		
		System.out.printf("논리 자료형: %b \n", isTrue); 
		System.out.printf("정수 자료형: %d, 정수 자료형: %d, 정수 자료형: %d, 정수 자료형: %d \n", byteNumber, shortNumber, intNumber, longNumber);
		System.out.printf("실수 자료형: %.3f, 실수 자료형: %.3f \n", floatNumber, doubleNumber);
		System.out.printf("문자 자료형: %c, 문자열 자료형: %s \n", money, str);
		System.out.printf("문자 자료형: %C, 문자열 자료형: %S \n", money, str);
	
		System.out.println("");
		
		String name = "Gemini";
		int age = 36;
		double height = 175.5;

		// 일반 출력 방식 (println)
		System.out.println("이름: " + name + ", 나이: " + age + ", 키: " + height);

		// 서식 출력 방식 (printf)
		System.out.printf("이름: %s, 나이: %d, 키: %.1f%n", name, age, height);
		
	}

}

package com.kh.first;

import javax.swing.*;
import java.awt.event.ActionEvent;
import java.awt.event.ActionListener;

public class HelloPikachu {
    public static void main(String[] args) {
        // 1. 프레임(창) 생성
        JFrame frame = new JFrame("피카츄 등장!");
        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        frame.setSize(400, 400);
        frame.setLayout(new java.awt.BorderLayout());

        // 2. 이미지 아이콘 생성 (이미지 파일명이 일치해야 합니다)
        // 코드와 같은 폴더에 'pikachu.png' 파일이 있어야 합니다.
        ImageIcon icon = new ImageIcon("C:/Users/user1/Downloads/pikachu.png");
        
        // 3. 이미지를 라벨에 담아 프레임에 추가
        JLabel label = new JLabel(icon);
        frame.add(label, java.awt.BorderLayout.CENTER);
        
        // --- 핵심 코드: 창을 화면 중앙으로 배치 ---
        JButton button = new JButton("피카츄 불러보기!");
        frame.add(button, java.awt.BorderLayout.SOUTH);
        // --------------------------------------
        
        // 버튼 클릭 이벤트 설정
        button.addActionListener(new ActionListener() {
            @Override
            public void actionPerformed(ActionEvent e) {
                System.out.println("피카-!");
                JOptionPane.showMessageDialog(frame, "반가워요!");
            }
        });
        
        // 4. 창을 화면에 표시
        frame.setLocationRelativeTo(null); 
        frame.setVisible(true);
    }
}
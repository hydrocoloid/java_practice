
public class Star {

	 public static void main(String[] args) {
	        // 5줄짜리 별 삼각형 만들기
	        for (int i = 1; i <= 5; i++) {       // 줄 바꿈을 위한 반복문
	            for (int j = 1; j <= i; j++) {   // 별 개수를 늘리기 위한 반복문
	                System.out.print("*");
	            }
	            System.out.println();            // 한 줄 다 찍으면 줄 바꿈
	        }
	    }
	}
package com.kh.first;

import javax.swing.*;
import java.awt.*;

public class HelloPikachu {
    public static void main(String[] args) {
        // 1. 프레임(창) 생성
        JFrame frame = new JFrame("피카츄 등장!");
        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        frame.setSize(400, 400);

        // 2. 이미지 아이콘 생성 (이미지 파일명이 일치해야 합니다)
        // 코드와 같은 폴더에 'pikachu.png' 파일이 있어야 합니다.
        ImageIcon icon = new ImageIcon("C:/Users/user1/Downloads/pikachu.png");
        
        // 3. 이미지를 라벨에 담아 프레임에 추가
        JLabel label = new JLabel(icon);
        frame.add(label);

        // 4. 창을 화면에 표시
        frame.setVisible(true);
    }
}
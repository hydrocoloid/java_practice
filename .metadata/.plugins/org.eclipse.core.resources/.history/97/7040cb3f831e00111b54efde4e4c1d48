	 * 자바에서 Memory = RAM
	 * 변수 = 램에 값을 저장하기 위한 '공간'
	 */
	
	public void 바지저장기능() {
		String 옷장 = "긴바지";
		String 행거 = "반바지";
		System.out.println(옷장);
		System.out.println(행거);
	}
	
	/* 변수를 사용했을 때의 장점
	 * 
	 */
	
	public void findLunchMenu() {
	/*점심메뉴 출력 프로그램
	 * 1. 메뉴 출력(메뉴명, 가격)
	 * 2. 주문했다고 가정
	 * 3. 내야 할 금액
	 */
		
		System.out.println("---변수를 사용하기 전---");
		System.out.println("메뉴판 > ");
		System.out.println("1. 트리플치즈버거 세트(15,000원)");
		System.out.println("2. 빅맥 세트(8,000원)");
		System.out.println("3. 1955버거 세트(11,000원)");
		
		// 트리플치즈버거 4명, 빅맥 9명, 1955 4명
		
		System.out.println("트리플치즈버거 세트 4개 주문");
		System.out.println("빅맥 세트 9개 주문");
		System.out.println("1955버거 세트 4개 주문");
	}
		
}
